# GoalSignal enrichment credentials and data paths (PLACEHOLDERS ONLY).
#
# Copy to `.env` and fill in real values. `.env` is git-ignored; never commit
# real keys. All enrichment sources are optional — the base forecasting
# workflow runs with none of these set.

# API-Sports / API-Football key (sent as the x-apisports-key header).
# Free plan: 100 requests/day. Sign up at https://www.api-football.com/
FOOTBALL_DATA_API_KEY=

# Local StatsBomb Open Data `data/` directory (competitions.json, matches/,
# lineups/, events/, three-sixty/). Clone https://github.com/statsbomb/open-data
STATSBOMB_DATA_PATH=

# Historical FIFA ranking timeline CSV (e.g. ranking_fifa_historical.csv).
FIFA_RANKINGS_PATH=

# Historical World Cup participant/rank validation CSV (e.g. wc_teams.csv).
FIFA_WC_TEAMS_PATH=

# Frozen current World Cup field snapshot (group, team, fifa_rank).
FIFA_CURRENT_RANKINGS_PATH=

# Transfermarkt-derived player/club history. A DuckDB file
# (transfermarkt-datasets.duckdb) OR a directory of gzipped CSV tables
# (the transfermarkt-datasets export). Opened read-only; never mutated.
PLAYER_DATA_PATH=

# Verified official FIFA/federation 2026 World Cup squad membership CSV.
FIFA_2026_SQUADS_PATH=

# Optional expanded official FIFA PDF extract used only for reconciliation.
FIFA_2026_SQUAD_EXTRACT_PATH=

# Optional conservative Transfermarkt candidate links used only after revalidation.
FIFA_2026_PLAYER_LINK_CANDIDATES_PATH=

# Optional timestamped player availability records, separate from membership.
FIFA_2026_AVAILABILITY_PATH=

# Optional human-reviewed squad-to-source player identity mappings.
FIFA_2026_PLAYER_ALIASES_PATH=
